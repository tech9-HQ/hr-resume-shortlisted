# ── Required ─────────────────────────────────────────────────────────────
# OpenAI key for AI question generation and answer scoring
OPENAI_API_KEY=sk-...

# PostgreSQL connection string (IBM Cloud Databases for PostgreSQL)
# Use sslmode=require for IBM Cloud
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ── Backend ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Set to your frontend URL in production (e.g. https://hr.yourdomain.com).
# Defaults to * (allow all) when not set.
CORS_ORIGINS=https://hr.yourdomain.com

# ── Optional: OneDrive resume ingestion (leave blank to disable) ──────────
ONEDRIVE_DRIVE_ID=
ONEDRIVE_FOLDER_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Required ─────────────────────────────────────────────────────────────
# OpenAI key for AI question generation and answer scoring
OPENAI_API_KEY=sk-...

# ── Backend ───────────────────────────────────────────────────────────────
# Path to DuckDB database file.
# In Docker / IBM Cloud Code Engine, point this at a mounted volume path.
DB_PATH=/app/data/resumes.duckdb

# Comma-separated list of allowed CORS origins.
# Set to your frontend URL in production (e.g. https://hr.yourdomain.com).
# Defaults to * (allow all) when not set.
CORS_ORIGINS=https://hr.yourdomain.com

# ── Optional: OneDrive resume ingestion (leave blank to disable) ──────────
ONEDRIVE_DRIVE_ID=
ONEDRIVE_FOLDER_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
